<Window x:Class="ElPretamita.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Estilo moderno para TextBox con iluminación (Glow) al enfocar -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#8B5CF6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="#1E1E2E" 
                                BorderBrush="#32324A" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="0" Color="#8B5CF6" Direction="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid Margin="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="10" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                             To="0.4" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter TargetName="border" Property="Background" Value="#161622"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo moderno para PasswordBox con iluminación (Glow) al enfocar -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0,12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#8B5CF6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" 
                                Background="#1E1E2E" 
                                BorderBrush="#32324A" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="0" Color="#8B5CF6" Direction="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <Grid Margin="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="10" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                             To="0.4" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B5CF6"/>
                                <Setter TargetName="border" Property="Background" Value="#161622"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón principal con degradado premium y micro-animaciones de escala (Hover y Click) -->
        <Style x:Key="ModernGradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#3B82F6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="btnBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4F46E5" Offset="0"/>
                                            <GradientStop Color="#2563EB" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0.97" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="btnBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.97" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Setter TargetName="btnBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4338CA" Offset="0"/>
                                            <GradientStop Color="#1D4ED8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilos para CheckBox Moderno -->
        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="18" Height="18" VerticalAlignment="Center">
                                    <Border x:Name="CheckBoxBorder" 
                                            Background="#1E1E2E" 
                                            BorderBrush="#32324A" 
                                            BorderThickness="1.5" 
                                            CornerRadius="4"/>
                                    <Path x:Name="CheckMark" 
                                          Data="M2,8 L6,12 L14,3" 
                                          Stroke="#8B5CF6" 
                                          StrokeThickness="2" 
                                          StrokeEndLineCap="Round" 
                                          StrokeStartLineCap="Round"
                                          Visibility="Collapsed"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Width="12" Height="10"
                                          Stretch="Fill"/>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#8B5CF6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo general para botones de control de ventana -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de Cerrar (Rojo al hacer Hover) -->
        <Style x:Key="CloseWindowControlButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para botón de ícono transparente sin bordes (Ojo) -->
        <Style x:Key="ModernIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Storyboards con atenuación y deslizamiento (Slide & Fade) para alertas -->
        <Storyboard x:Key="FadeInAlert">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-25" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        
        <Storyboard x:Key="FadeOutAlert">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-20" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.3" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <!-- Trigger de Carga para Animación de Entrada Secuencial (Staggered) -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Animación Panel Izquierdo (Marca) -->
                    <DoubleAnimation Storyboard.TargetName="LeftPanelContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LeftPanelContent"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="40" To="0" Duration="0:0:0.8">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Animación Panel Derecho - Título (Retraso 0.15s) -->
                    <DoubleAnimation Storyboard.TargetName="RightPanelHeader"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.15">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RightPanelHeader"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="-25" To="0" Duration="0:0:0.6" BeginTime="0:0:0.15">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Campo Usuario (Retraso 0.3s) -->
                    <DoubleAnimation Storyboard.TargetName="FieldUsuario"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="FieldUsuario"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="20" To="0" Duration="0:0:0.6" BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Campo Contraseña (Retraso 0.42s) -->
                    <DoubleAnimation Storyboard.TargetName="FieldPassword"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.42">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="FieldPassword"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="20" To="0" Duration="0:0:0.6" BeginTime="0:0:0.42">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Fila Checkbox/Recordar (Retraso 0.52s) -->
                    <DoubleAnimation Storyboard.TargetName="FieldRemember"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.52">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="FieldRemember"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="10" To="0" Duration="0:0:0.6" BeginTime="0:0:0.52">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Botón Enviar (Retraso 0.62s) -->
                    <DoubleAnimation Storyboard.TargetName="FieldSubmit"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.62">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="FieldSubmit"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="15" To="0" Duration="0:0:0.6" BeginTime="0:0:0.62">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <!-- Borde principal con esquinas redondeadas y sombra paralela de gran suavidad -->
        <Border CornerRadius="16" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Color="#000000" Direction="320" ShadowDepth="5" Opacity="0.65"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Columna 0: Panel Izquierdo (Presentación y Marca) -->
                <Grid Grid.Column="0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1E1B4B" Offset="0"/>
                            <GradientStop Color="#0F0F1A" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Formas decorativas sutiles para estética premium -->
                    <Canvas Opacity="0.3">
                        <Ellipse Width="300" Height="300" Canvas.Left="-100" Canvas.Top="-100">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#4F46E5" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Width="350" Height="350" Canvas.Right="-150" Canvas.Bottom="-150">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#06B6D4" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Canvas>

                    <!-- Brillo radial detrás del logotipo -->
                    <Border Width="220" Height="220" CornerRadius="110" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.12" Margin="0,0,0,100">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Logotipo y Nombre del Sistema (Animado) -->
                    <StackPanel x:Name="LeftPanelContent" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,40" Opacity="0" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </StackPanel.RenderTransform>

                        <Border CornerRadius="20" Background="#1A1A2E" Padding="15" Margin="0,0,0,25" HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.4" ShadowDepth="2"/>
                            </Border.Effect>
                            <Image x:Name="ImgLogo"
                                   Source="/Assets/el logo personal.png" 
                                   Width="140" 
                                   Height="140" 
                                   Stretch="Uniform"/>
                        </Border>

                        <TextBlock Text="AM Prestamos"
                                   FontSize="38"
                                   FontWeight="ExtraBold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#E2E8F0" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>

                        <TextBlock Text="Sistema Financiero &amp; Sam"
                                   FontSize="16"
                                   Foreground="#818CF8"
                                   FontWeight="Medium"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Nota de Pie de Página -->
                    <TextBlock Text="© 2026 AM Prestamos. Todos los derechos reservados." 
                               Foreground="#4B5563" 
                               FontSize="11" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Bottom" 
                               Margin="0,0,0,25"/>
                </Grid>

                <!-- Columna 1: Panel Derecho (Formulario de Acceso) -->
                <Grid Grid.Column="1" Background="#0F172A">
                    <!-- Botones de Control de Ventana -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0">
                        <Button Style="{StaticResource WindowControlButton}" Click="BtnMinimizar_Click" ToolTip="Minimizar">
                            <TextBlock Text="─" FontSize="14" Foreground="#94A3B8" FontWeight="Bold"/>
                        </Button>
                        <Button Style="{StaticResource CloseWindowControlButton}" Click="BtnCerrar_Click" ToolTip="Cerrar" Margin="5,0,0,0">
                            <TextBlock Text="✕" FontSize="14" Foreground="#94A3B8" FontWeight="Bold"/>
                        </Button>
                    </StackPanel>

                    <!-- Formulario de Entrada -->
                    <StackPanel Width="360" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                        
                        <!-- Encabezado del Formulario (Animado) -->
                        <StackPanel x:Name="RightPanelHeader" Opacity="0" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,0">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </StackPanel.RenderTransform>
                            
                            <TextBlock Text="¡Bienvenido de nuevo!"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Ingresa tus credenciales para acceder al sistema"
                                       FontSize="13"
                                       Foreground="#64748B"
                                       Margin="0,0,0,25"/>
                        </StackPanel>

                        <!-- ALERTA: Mensaje de Error (Deslizamiento con Easing) -->
                        <Border x:Name="ErrorAlert" 
                                Background="#2D1F24" 
                                BorderBrush="#EF4444" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="12" 
                                Margin="0,0,0,15" 
                                Visibility="Collapsed"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚠" Foreground="#EF4444" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="ErrorAlertText" Grid.Column="1" Text="Usuario o contraseña incorrectos." Foreground="#FCA5A5" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- ALERTA: Mensaje de Éxito (Deslizamiento con Easing) -->
                        <Border x:Name="SuccessAlert" 
                                Background="#142B24" 
                                BorderBrush="#10B981" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="12" 
                                Margin="0,0,0,15" 
                                Visibility="Collapsed"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✓" Foreground="#10B981" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="SuccessAlertText" Grid.Column="1" Text="¡Ingreso correcto! Redirigiendo..." Foreground="#A7F3D0" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- Entrada de Usuario (Animado) -->
                        <Grid x:Name="FieldUsuario" Opacity="0" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,20">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Grid.RenderTransform>

                            <TextBox x:Name="TxtUsuario"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="15,0,15,0"
                                     Height="45"
                                     GotFocus="TxtUsuario_GotFocus"
                                     LostFocus="TxtUsuario_LostFocus"
                                     TextChanged="TxtUsuario_TextChanged"
                                     TabIndex="1"/>

                            <TextBlock x:Name="TxtUsuarioWatermark"
                                       Text="Introduce tu usuario"
                                       FontSize="14"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"
                                       Foreground="#5F5F7A"
                                       Opacity="1"/>
                        </Grid>

                        <!-- Entrada de Contraseña (Animado) -->
                        <Grid x:Name="FieldPassword" Opacity="0" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,20">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Grid.RenderTransform>
                            
                            <!-- El PasswordBox -->
                            <PasswordBox x:Name="TxtPassword"
                                         Style="{StaticResource ModernPasswordBox}"
                                         Padding="15,0,45,0"
                                         Height="45"
                                         PasswordChanged="TxtPassword_PasswordChanged"
                                         GotFocus="TxtPassword_GotFocus"
                                         LostFocus="TxtPassword_LostFocus"
                                         TabIndex="2"/>

                            <!-- El TextBox Unmasked -->
                            <TextBox x:Name="TxtPasswordUnmasked"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="15,0,45,0"
                                     Height="45"
                                     Visibility="Collapsed"
                                     TextChanged="TxtPasswordUnmasked_TextChanged"
                                     GotFocus="TxtPasswordUnmasked_GotFocus"
                                     LostFocus="TxtPasswordUnmasked_LostFocus"
                                     TabIndex="2"/>

                            <!-- Watermark único compartido para la contraseña -->
                            <TextBlock x:Name="TxtPasswordWatermark"
                                       Text="Introduce tu contraseña"
                                       FontSize="14"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"
                                       Foreground="#5F5F7A"
                                       Opacity="1"/>

                             <!-- Botón de Ojo (Vectorial Abierto/Cerrado) -->
                             <Button x:Name="BtnTogglePassword"
                                     Style="{StaticResource ModernIconButton}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"
                                     Margin="0,0,15,0"
                                     Click="BtnTogglePassword_Click"
                                     Focusable="False"
                                     Width="22" Height="22">
                                 <Grid>
                                     <!-- Ojo Abierto (Contraseña Visible) -->
                                     <Path x:Name="PathEyeOpen"
                                           Data="M1,10 C1,10 4,3 10,3 C16,3 19,10 19,10 C19,10 16,17 10,17 C4,17 1,10 1,10 Z M10,14 C12.2,14 14,12.2 14,10 C14,7.8 12.2,6 10,6 C7.8,6 6,7.8 6,10 C6,12.2 7.8,14 10,14 Z M10,12 C11.1,12 12,11.1 12,10 C12,8.9 11.1,8 10,8 C8.9,8 8,8.9 8,10 C8,11.1 8.9,12 10,12 Z"
                                           Fill="#8B5CF6"
                                           Stretch="Uniform"
                                           Visibility="Collapsed"/>
                                           
                                     <!-- Ojo Cerrado (Contraseña Oculta) -->
                                     <Path x:Name="PathEyeClosed"
                                           Data="M10,3 C16,3 19,10 19,10 C19,10 17,14 14.5,15.8 M8,16.5 C5,15 1,10 1,10 C1,10 4,3 10,3 Z M10,14 C12.2,14 14,12.2 14,10 C14,7.8 12.2,6 10,6 C7.8,6 6,7.8 6,10 C6,12.2 7.8,14 10,14 Z M1.5,1.5 L18.5,18.5"
                                           Stroke="#5F5F7A"
                                           StrokeThickness="1.5"
                                           StrokeStartLineCap="Round"
                                           StrokeEndLineCap="Round"
                                           Fill="Transparent"
                                           Stretch="Uniform"
                                           Visibility="Visible"/>
                                 </Grid>
                             </Button>
                        </Grid>

                        <!-- Recordar Contraseña / Olvido de credenciales (Animado) -->
                        <Grid x:Name="FieldRemember" Margin="0,0,0,25" Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Grid.RenderTransform>
                            
                            <CheckBox x:Name="ChkRecordarme"
                                      Content="Recuérdame" 
                                      Style="{StaticResource ModernCheckBoxStyle}" 
                                      HorizontalAlignment="Left"
                                      TabIndex="3"/>
                            <TextBlock Text="¿Olvidaste tu contraseña?"
                                       Foreground="#8B5CF6"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="BtnOlvideContrasena_Click"/>
                        </Grid>

                        <!-- Botón de Entrada con barra de carga (Animado) -->
                        <Grid x:Name="FieldSubmit" Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Grid.RenderTransform>
                            
                            <Button x:Name="BtnIngresar"
                                    Content="Entrar" 
                                    Style="{StaticResource ModernGradientButton}"
                                    Click="BtnIngresar_Click"
                                    TabIndex="4"/>
                            <ProgressBar x:Name="LoadingProgress"
                                         IsIndeterminate="True"
                                         Height="4"
                                         VerticalAlignment="Bottom"
                                         Background="Transparent"
                                         Foreground="#8B5CF6"
                                         BorderThickness="0"
                                         Visibility="Collapsed"
                                         Margin="5,0,5,2"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>