<Window x:Class="ElPretamita.Views.Compartido.ContratoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resumen de Préstamo y Pagaré" Height="850" Width="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1E1E2E" CornerRadius="15" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera Fuera de Impresión -->
            <TextBlock Grid.Row="0" Text="Vista Previa para Imprimir" Foreground="#10B981" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <!-- ÁREA IMPRIMIBLE (Diseño de la Imagen) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                <Border x:Name="AreaImprimible" Background="White" CornerRadius="0" Padding="40">
                    <StackPanel>
                        
                        <!-- Rectángulo Superior Oscuro -->
                        <Border Background="#16202B" Padding="20" Margin="0,0,0,30">
                            <StackPanel>
                                <TextBlock Text="RESUMEN DE PRÉSTAMO Y PAGARÉ" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Documento Privado de Obligación Financiera" FontSize="14" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Sección 1: DATOS DEL CRÉDITO -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="4" Background="#1C3D5A" Margin="0,0,10,0"/>
                            <TextBlock Text="DATOS DEL CRÉDITO" FontSize="18" FontWeight="Bold" Foreground="#1C3D5A"/>
                        </StackPanel>

                        <!-- Tabla de Datos -->
                        <Border BorderBrush="#E5E7EB" BorderThickness="1,1,1,0" Margin="0,0,0,30">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Fila 1 -->
                                <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="#F9FAFB"/>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Fecha de Emisión:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtFecha" Text="---" Foreground="#111827" Padding="10"/>

                                <!-- Fila 2 -->
                                <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="White"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Cliente (Deudor):" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RunNombre" Text="---" Foreground="#111827" Padding="10"/>

                                <!-- Fila 3 -->
                                <Border Grid.Row="2" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="#F9FAFB"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Cédula de Identidad:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RunCedula" Text="---" Foreground="#111827" Padding="10"/>

                                <!-- Fila 4 -->
                                <Border Grid.Row="3" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="White"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Monto Dispuesto:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RunMonto" Text="---" Foreground="#111827" Padding="10"/>

                                <!-- Fila 5 -->
                                <Border Grid.Row="4" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="#F9FAFB"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Total a Pagar:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RunTotal" Text="---" Foreground="#111827" Padding="10"/>

                                <!-- Fila 6 -->
                                <Border Grid.Row="5" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="White"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Estructura de Pagos:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="10">
                                    <TextBlock x:Name="RunCuotas" Text="---" Foreground="#111827"/>
                                    <TextBlock x:Name="RunTipoCuota" Text=" cuotas consecutivas" Foreground="#111827"/>
                                </StackPanel>

                                <!-- Fila 7 -->
                                <Border Grid.Row="6" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Background="#F9FAFB"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Valor de la Cuota:" FontWeight="Bold" Foreground="#4B5563" Padding="10"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="RunValorCuota" Text="---" Foreground="#111827" Padding="10"/>
                            </Grid>
                        </Border>

                        <!-- Sección 2: PAGARÉ Y CLÁUSULAS -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="4" Background="#1C3D5A" Margin="0,0,10,0"/>
                            <TextBlock Text="PAGARÉ Y CLÁUSULAS DE CUMPLIMIENTO" FontSize="18" FontWeight="Bold" Foreground="#1C3D5A"/>
                        </StackPanel>

                        <!-- Caja con borde punteado -->
                        <Border BorderBrush="#9CA3AF" BorderThickness="1" Padding="20" Margin="0,0,0,50">
                            <!-- En WPF no hay StrokeDashArray directo en Border, pero podemos simularlo visualmente con un estilo sólido o usar Rectangle -->
                            <Border.Background>
                                <SolidColorBrush Color="Transparent"/>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="13" LineHeight="20" TextAlignment="Justify" Margin="0,0,0,15">
                                    <Run Text="PAGARÉ CORRIDO Y RECONOCIMIENTO DE DEUDA: " FontWeight="Bold"/>
                                    <Run Text="Yo, "/>
                                    <Run x:Name="RunNombrePagare" FontWeight="Bold" Text="---"/>
                                    <Run Text=", de las generales anteriormente descritas, por medio del presente documento reconozco de manera libre y voluntaria que adeudo legítimamente a favor del acreedor la suma de "/>
                                    <Run x:Name="RunTotalPagare" FontWeight="Bold" Text="---"/>
                                    <Run Text=". Me comprometo formalmente a realizar el pago total de dicha obligación en las fechas y montos estipulados en la tabla de pagos de este documento."/>
                                </TextBlock>

                                <TextBlock TextWrapping="Wrap" Foreground="#374151" FontSize="13" LineHeight="20" TextAlignment="Justify">
                                    <Run Text="CLÁUSULA DE MORA E INCUMPLIMIENTO: " FontWeight="Bold"/>
                                    <Run Text="El retraso en el pago de cualquiera de las cuotas devengará de pleno derecho, y sin necesidad de puesta en mora previa, "/>
                                    <Run x:Name="RunTextoMora" FontWeight="Bold" Text="un interés moratorio del cinco por ciento (5%) mensual sobre el saldo en atraso"/>
                                    <Run Text=". La falta de pago de tres (3) de las cuotas de este resumen hará exigible la totalidad de la deuda restante de forma inmediata."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Zona de Firmas (Alineadas a la izquierda como en la imagen) -->
                        <StackPanel HorizontalAlignment="Left" Margin="20,0,0,0">
                            <!-- Firma Cliente -->
                            <StackPanel Margin="0,0,0,20">
                                <!-- Espacio para firmar y línea -->
                                <Border BorderBrush="#4B5563" BorderThickness="0,0,0,1" Width="250" Margin="0,50,0,5" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="RunNombreFirma" Text="---" Foreground="#374151" FontSize="13" HorizontalAlignment="Center" Width="250" TextAlignment="Center"/>
                                <TextBlock Text="Deudor / Cliente" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" Width="250" TextAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center" Width="250" TextAlignment="Center" Foreground="#6B7280" FontSize="12" Margin="0,2,0,0">
                                    <Run Text="Céd.: "/>
                                    <Run x:Name="RunCedulaFirma" Text="---"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Firma Acreedor -->
                            <StackPanel Margin="0,0,0,20">
                                <!-- Espacio para firmar y línea -->
                                <Border BorderBrush="#4B5563" BorderThickness="0,0,0,1" Width="250" Margin="0,50,0,5" HorizontalAlignment="Left"/>
                                <TextBlock Text="Acreedor Autorizado" Foreground="#374151" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Width="250" TextAlignment="Center"/>
                                <TextBlock Text="Firma y Sello del Prestador" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" Width="250" TextAlignment="Center"/>
                                <TextBlock Text="AM Prestamos" Foreground="#6B7280" FontSize="12" HorizontalAlignment="Center" Width="250" TextAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Botones de Acción -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="❌ Cancelar / Editar" Background="#475569" Foreground="White" Padding="10" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="2">
                    <Button Content="🖨️ Imprimir Resumen" Background="#3B82F6" Foreground="White" Padding="10" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="BtnImprimir_Click" Margin="0,0,0,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="✅ Proceder y Guardar" Background="#10B981" Foreground="White" Padding="10" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Click="BtnProceder_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
